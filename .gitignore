.env
.env.*
!.env.example
*.secret
.xero_tokens.json
secrets/
dev.ps1
__pycache__/
*.pyc
.venv/
node_modules/
reports/*.pdf
.pytest_cache/

# Historical data — keep templates, ignore actual financial CSVs
data/historical/*.csv
!data/historical/template.csv
!data/historical/sample_*.csv

# Snapshot data — generated, not committed (except pinned AGM snapshots)
data/snapshots/*.json

# Financial data — never commit actual numbers
budgets/*.yaml
budgets/*.json
!budgets/*.sample.yaml
!budgets/README.md
config/payroll.yaml
config/properties.yaml
!config/*.sample.yaml

# Sync scratch + dev error logs
data/sync/
reload_err.txt
server_err*.txt
